.51.192:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     42.118.51.192:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     42.118.51.192:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     42.118.51.192:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     42.118.51.192:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict-batch HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"GET /health HTTP/1.1\" 200 OK\n", "INFO:     159.223.33.155:0 - \"POST /predict HTTP/1.1\" 200 OK\n"]}], "source": ["import nest_asyncio\n", "import uvicorn\n", "from fastapi import FastAPI, HTTPException\n", "from pydantic import BaseModel\n", "from typing import List\n", "import torch\n", "import numpy as np\n", "\n", "# 1. Cho phép chạy async trong Notebook\n", "nest_asyncio.apply()\n", "\n", "app = FastAPI()\n", "\n", "class CommentData(BaseModel):\n", "    comment: str\n", "\n", "class BatchData(BaseModel):\n", "    comments: List[str]\n", "\n", "def extract_features_for_texts(texts):\n", "    # Tokenize\n", "    inputs = tokenizer(\n", "        texts,\n", "        padding=True,\n", "        truncation=True,\n", "        max_length=MAX_LEN,\n", "        return_tensors=\"pt\"\n", "    )\n", "    inputs = {k: v.to(device) for k, v in inputs.ittôis()}\n", "\n", "    # Fine-tuned PhoBERT tôibeddings ([CLS])\n", "    with torch.no_grad():\n", "        outputs = base_model(input_ids=inputs['input_ids'], attention_mask=inputs['attention_mask'])\n", "        tôibeddings = outputs.last_hidden_state[:, 0, :].detach().cpu().numpy()\n", "\n", "    # Handcrafted features (must match training pipeline)\n", "    hc = np.array([extract_handcrafted_features(t) for t in texts], dtype=np.float32)\n", "\n", "    # Combined features: 768 + 12 = 780\n", "    X = np.hstack([tôibeddings, hc])\n", "    return X\n", "\n", "# 2. Hàm dự đoán\n", "def model_predict(texts):\n", "    if 'base_model' not in globals() or 'best_xgb' not in globals():\n", "        raise RuntimeError('base_model hoặc best_xgb chưa được load. Hãy chạy cell load checkpoint trước.')\n", "\n", "    X = extract_features_for_texts(texts)\n", "    probs = best_xgb.predict_proba(X)[:, 1]\n", "    return probs.tolist()\n", "\n", "# 3. Endpoints\n", "@app.get(\"/health\")\n", "def health():\n", "    ready = ('base_model' in globals() and 'best_xgb' in globals())\n", "    return {\"status\": \"online\", \"ready\": ready, \"model\": \"PhoBERT-XGBoost-Enstôible\"}\n", "\n", "@app.post(\"/predict\")\n", "def predict(data: CommentData):\n", "    try:\n", "        res = model_predict([data.comment])\n", "        return {\"prediction\": float(res[0])}\n", "    except Exception as e:\n", "        raise HTTPException(status_code=500, detail=str(e))\n", "\n", "@app.post(\"/predict-batch\")\n", "def predict_batch(data: BatchData):\n", "    try:\n", "        res = model_predict(data.comments)\n", "        return {\"predictions\": [float(x) for x in res]}\n", "    except Exception as e:\n", "        raise HTTPException(status_code=500, detail=str(e))\n", "\n", "# 4. Khởi động Server\n", "print(\"🚀 Server đang khởi động tại link Ngrok của người dùng...\")\n", "config = uvicorn.Config(app, host=\"0.0.0.0\", port=8000, loop=\"asyncio\")\n", "server = uvicorn.Server(config)\n", "await server.serve()"]}], "metadata": {"accelerator": "GPU", "colab": {"gpuType": "T4", "provenance": []}, "kernelspec": {"display_name": "Python 3 (ipykernel)", "language": "python", "name": "python3"}}, "nbformat": 4, "nbformat_minor": 0}